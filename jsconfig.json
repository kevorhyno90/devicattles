{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "noEmit": true,
    "maxNodeModuleJsDepth": 0,
    "types": ["vite/client"]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "vite.config.js",
    "jest.config.js",
    "jest.config.mjs"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "public",
    "assets",
    "scripts",
    "coverage"
  ]
}

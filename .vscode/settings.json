{
    "python-envs.defaultEnvManager": "ms-python.python:system",
    "python-envs.pythonProjects": [],
    "typescript.tsserver.maxTsServerMemory": 4096,
    "typescript.tsserver.log": "off",
    "typescript.disableAutomaticTypeAcquisition": true,
    "typescript.enablePromptUseWorkspaceTsdk": false,
    "typescript.surveys.enabled": false,
    "typescript.check.npmIsInstalled": false,
    "js/ts.implicitProjectConfig.checkJs": false,
    "[javascript]": {"editor.defaultFormatter": null, "editor.formatOnSave": false},
    "[typescript]": {"editor.defaultFormatter": null, "editor.formatOnSave": false},
    "[jsx]": {"editor.defaultFormatter": null},
    "[tsx]": {"editor.defaultFormatter": null},
    "editor.codeActionsOnSave": {},
    "editor.formatOnSave": false,
    "javascript.validate.enable": false,
    "extensions.ignoreRecommendations": true,
    "telemetry.telemetryLevel": "off",
    "workbench.settings.enableNaturalLanguageSearch": false,
    "workbench.startupEditor": "none",
    "extensions.recommendations": [],
    "gitlens.telemetry.enabled": false,
    "[html]": {"editor.defaultFormatter": null},
    "[css]": {"editor.defaultFormatter": null},
    "[json]": {"editor.defaultFormatter": null},
    "diffEditor.ignoreTrimWhitespace": true,
    "typescript.tsserver.watchOptions": {
        "watchFile": "useFsEventsOnParentDirectory",
        "watchDirectory": "useFsEvents",
        "fallbackPolling": "dynamicPriority"
    },
    "typescript.tsserver.useSeparateSyntaxServer": true,
    "typescript.tsserver.experimental.enableProjectDiagnostics": false
}